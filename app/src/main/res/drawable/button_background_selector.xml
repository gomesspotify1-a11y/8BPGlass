<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@+id/selected" android:drawable="@drawable/button_gradient_active" android:state_selected="true" />
    <item android:id="@+id/normal" android:drawable="@drawable/button_gradient" />

    <transition
        android:fromId="@id/normal"
        android:toId="@id/selected"
        android:drawable="@drawable/button_gradient_active"
        android:reversible="true" />

    <transition
        android:fromId="@id/selected"
        android:toId="@id/normal"
        android:drawable="@drawable/button_gradient"
        android:reversible="true" />
</animated-selector>
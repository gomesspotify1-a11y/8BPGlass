<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Задний полупрозрачный фон -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12424242"/>
            <corners android:radius="42dp"/>
        </shape>
    </item>

    <!-- Светлая граница сверху-слева -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.2dp"
                android:color="#895B5B5B"/>
            <corners android:radius="42dp"/>
        </shape>
    </item>

</layer-list>
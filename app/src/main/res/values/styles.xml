<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CustomButton" parent="Widget.MaterialComponents.Button">
    <item name="android:background">@drawable/button_background_selector</item>
    <item name="android:backgroundTint">@null</item>
    <item name="backgroundTint">@null</item>
    <item name="rippleColor">@android:color/transparent</item>
    <item name="elevation">0dp</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
</style>

    <style name="CustomLoginButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_gradient</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="elevation">0dp</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <style name="RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>


    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/MyBottomSheet</item>
        <item name="android:windowIsTranslucent">false</item>

        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowBackground">#7A000000</item>
    </style>

    <style name="MyBottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">#8F000000</item>
        <item name="android:layout_height">match_parent</item>
        <item name="buttonStyle">@style/BottomSheetButtonStyle</item>
    </style>

    <style name="NavDrawerTextStyle" parent="TextAppearance.Material3.BodyLarge">
            <item name="android:fontFamily">@font/inter_medium</item>
            <item name="android:textSize">15sp</item>
            <item name="android:textColor">@color/white</item>
        </style>

        <style name="CustomNavigationViewStyle" parent="Widget.Material3.NavigationView">
            <item name="itemIconPadding">12dp</item>
            <item name="itemRippleColor">@color/ripple_no_effect</item>
            <item name="itemTextAppearance">@style/NavDrawerTextStyle</item>
        </style>
    <style name="BottomSheetButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="Theme.XProject.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="android:windowBackground">@drawable/splash_bg</item>
    <item name="android:windowNoTitle">true</item>
    <item name="android:windowFullscreen">true</item>
</style>

</resources>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фоновое изображение на весь экран -->
    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/fragment_delta" />

    <!-- Весь основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <!-- Фото с кнопкой -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.8">

            <View
                android:id="@+id/fragmentimage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent" />


            <LinearLayout
                android:id="@+id/root_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#00ED0000"
                android:paddingTop="30dp">

                <RelativeLayout
                    android:id="@+id/header_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="#00000000">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp">

                            <eightbitlab.com.blurview.BlurView
                                android:id="@+id/blur_back_button"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clipToOutline="true"
                                android:background="@drawable/bg_circle2" />

                            <ImageView
                                android:id="@+id/back_button"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_circle2"
                                android:src="@drawable/chevron_left"
                                android:scaleType="center"
                                android:contentDescription="Left"
                                android:padding="10dp" />
                        </FrameLayout>

                    </FrameLayout>

                </RelativeLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <FrameLayout
                        android:id="@+id/contenttt"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">


                    </FrameLayout>

                </FrameLayout>

                <!-- Нижняя навигация -->

                <FrameLayout
                    android:id="@+id/fragment_container2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="#CC000000" />

            </LinearLayout>



        </FrameLayout>

        <!-- Черный скругленный блок с текстом и кнопкой внизу -->
        <FrameLayout
            android:id="@+id/bottom_card_block"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:background="@drawable/button_gradient"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="@dimen/navigation_bar_padding">

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/blurViewCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:background="@drawable/button_gradient" />

            <!-- Контейнер с padding только для текста и кнопок -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingStart="24dp"
            android:paddingBottom="24dp">
                <!-- Текстовый контент, кнопки и т.д. (без слайдера) -->
                <!-- ... сюда перенести только текстовые элементы ... -->
            <!-- Текстовый контент -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Группа: иконка + название + подпись -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/game_icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/pubgmgl"
                        android:contentDescription="Game Icon"
                        android:layout_marginEnd="12dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_circle_oval"
                            android:clipToOutline="true" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/fragmentgamename"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/delta_force"
                            android:fontFamily="@font/figtree_semibold"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/fragmentpublisher"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/figtree_semibold"
                            android:text="@string/by_x_project"
                            android:textColor="@android:color/darker_gray"
                            android:layout_marginTop="6dp"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                    <!-- Кастомные radio кнопки -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/radio_basic"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                           
                            android:text=" "
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/figtree_semibold"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true" />



                    </LinearLayout>

                    <!-- Вертикальный скролл для длинного описания -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        android:overScrollMode="ifContentScrolls"
                        android:scrollbars="none">
                <TextView
                    android:id="@+id/fragmentdescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/figtree_medium"
                            android:text="@string/delta_force_description"
                    android:textColor="#72C3C3C3"
                    android:textSize="12sp" />
                    </ScrollView>
            </LinearLayout>

            <!-- Индикатор прогресса -->
            <FrameLayout
                android:id="@+id/progressOverlay"
                android:background="#99000000"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <ProgressBar
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </FrameLayout>
            </LinearLayout>

            <!-- Слайдер вне LinearLayout, без padding -->
            <eightbitlab.com.blurview.BlurView
                android:id="@+id/blurViewSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:background="@drawable/button_gradient">

                <FrameLayout
                    android:id="@+id/custom_slider_container"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/background_card">

                    <!-- Центрированный текст -->
                    <TextView
                        android:id="@+id/slider_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/figtree_semibold"
                        android:text="@string/slide_to_launch"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"/>

                    <!-- Фон слайдера -->
                    <View
                        android:id="@+id/custom_slider_track"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/button_gradient" />

                    <!-- Thumb (ползунок) -->
                    <ImageView
                        android:id="@+id/btnSignIn"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginEnd="8dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_circle"
                        android:src="@drawable/arrow_right"
                        android:contentDescription="right_icon2"
                        android:translationX="0dp" />
                </FrameLayout>
            </eightbitlab.com.blurview.BlurView>
        </FrameLayout>
    </LinearLayout>


</FrameLayout>